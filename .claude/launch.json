{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Control Panel",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm", "--prefix", "control-panel", "run", "dev", "--", "--host"],
      "port": 5173
    },
    {
      "name": "Storybook",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm", "--prefix", "control-panel", "run", "storybook"],
      "port": 6006
    }
  ]
}
