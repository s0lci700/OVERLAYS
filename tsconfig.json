{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "paths": {
      "@contracts/*": ["./control-panel/src/lib/contracts/*"]
    }
  },
  "include": [
    "server.ts",
    "src/**/*",
    "control-panel/src/lib/contracts/**/*.ts"
  ],
  "exclude": ["node_modules", "control-panel/node_modules"]
}
